    <script>
        // 아이콘 렌더링
        lucide.createIcons();

        // 1. 스크롤 애니메이션 (요소가 화면에 나타날 때 스르륵 등장)
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 100;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }
        window.addEventListener("scroll", reveal);
        reveal(); // 로딩 시 초기 실행

        // 2. 카카오톡 API
        const kakaoJSKey = '1aa968a094a900e05010d7b54c35e006'; 
        if(!Kakao.isInitialized()) { Kakao.init(kakaoJSKey); }

        function shareKakao() {
            if(!Kakao.isInitialized()) {
                alert('카카오 API 설정에 문제가 있습니다.');
                return;
            }
            const campaignUrl = 'https://djmonnar.github.io/jinhae/'; 
            Kakao.Share.sendDefault({
                objectType: 'feed',
                content: {
                    title: '진해의 도약!! 진해의 선택!! 박동철 도의원',
                    description: '박동하는 진해, 지금이 확실히 밀어줄 철입니다!',
                    imageUrl: 'https://i.ibb.co/6JyFRkTd/Kakao-Talk-20260326-143941240.jpg', 
                    link: { mobileWebUrl: campaignUrl, webUrl: campaignUrl },
                },
                buttons: [{ title: '후보자 프로필 보기', link: { mobileWebUrl: campaignUrl, webUrl: campaignUrl } }],
            });
        }
    </script>
